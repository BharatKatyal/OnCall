# Copy to .env and fill in. .env is gitignored.

# --- API keys (can live here or in the workspace-root .env; both are loaded) ---
DEEPGRAM_API_KEY=your-deepgram-key
ANTHROPIC_API_KEY=sk-ant-...

# --- Redis incident-memory plane ---
# Cloud Redis (single connection string, takes precedence if set):
REDIS_URL=redis://default:<password>@<host>:<port>

# Or local Docker Redis Stack (used when REDIS_URL is unset):
# REDIS_HOST=localhost
# REDIS_PORT=6380
# REDIS_PASSWORD=

# --- Kubernetes (read-only cluster debugging) ---
# Path to the oncall-readonly kubeconfig. Defaults to /tmp/oncall-kubeconfig,
# else the caller's default kubeconfig. Re-mint the token (8h) before a demo:
#   TOKEN=$(kubectl create token oncall-readonly -n default --duration=8h)
# ONCALL_KUBECONFIG=/tmp/oncall-kubeconfig
